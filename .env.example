# ── LLM endpoint ────────────────────────────────────────────────────────────
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-5
LLM_API_VERSION=        # Azure only; leave empty for Mammouth

# ── Safety ───────────────────────────────────────────────────────────────────
APPROVAL_MODE=always    # always | destructive_only | never
QUARANTINE_DIR=_quarantine
JOURNAL_PATH=.organizer/journal.jsonl

# ── Egress / extraction ──────────────────────────────────────────────────────
MAX_SNIPPET_CHARS=4000
ALLOWLIST_DIRS=         # optional: JSON array, e.g. ["C:/Users/me/docs"]
